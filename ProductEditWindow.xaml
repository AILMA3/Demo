<Window x:Class="Demo.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="Редактирование товара" Height="650" Width="800"
        Closed="Window_Closed">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtWindowTitle" FontSize="20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="ID товара:"/>
            <TextBox x:Name="txtId" IsReadOnly="True"/>
            <TextBlock Text="Фото товара:"/>
            <Image x:Name="imgProduct" Source="{Binding DisplayImagePath, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Выбрать изображение" Click="BtnSelectImage_Click" Height="30" Width="150"/>
                <Button Content="Удалить изображение" Click="BtnDeleteImage_Click" Height="30" Width="150"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Наименование товара:"/>
            <TextBox x:Name="txtName"/>

            <TextBlock Text="Категория товара:"/>
            <ComboBox x:Name="cmbCategory"/>

            <TextBlock Text="Описание товара:"/>
            <TextBox x:Name="txtDescription" TextWrapping="Wrap"/>

            <TextBlock Text="Производитель товара:"/>
            <ComboBox x:Name="cmbManufacturer"/>

            <TextBlock Text="Поставщик товара:"/>
            <ComboBox x:Name="cmbSupplier"/>

            <TextBlock Text="Цена товара:"/>
            <TextBox x:Name="txtPrice"/>

            <TextBlock Text="Единица измерения товара:"/>
            <ComboBox x:Name="cmbMeasure"/>

            <TextBlock Text="Скидка на товар:"/>
            <TextBox x:Name="txtDiscount"/>

            <TextBlock Text="Количество на складе:"/>
            <TextBox x:Name="txtCount"/>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="txtError" Grid.Row="3" TextWrapping="Wrap"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="100" Height="30" Click="BtnSave_Click"/>
                <Button Content="Отмена" Width="100" Height="30" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
