<Window x:Class="Demo.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="Управление заказами" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Список заказов -->
        <ListBox x:Name="listOrders"
                 Grid.Row="0"
                 SelectionChanged="listOrders_SelectionChanged">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Артикул товара: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding ProductsInfo}" FontWeight="Bold"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Статус заказа: "/>
                                <TextBlock Text="{Binding Status.Name}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Адрес пункта выдачи: "/>
                                <TextBlock Text="{Binding PickupPoint.FullAddress}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Дата заказа: "/>
                                <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                            <TextBlock Text="Дата доставки" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding DeliveryDate, StringFormat={}{0:dd.MM.yyyy}}" HorizontalAlignment="Center"/>

                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnAddOrder" 
                    Content="Добавить заказ"
                    Width="120" Height="32"
                    Click="btnAddOrder_Click"/>
            <Button Content="Закрыть"
                    Width="80" Height="32"
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
