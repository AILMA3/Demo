<Window x:Class="Demo.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="Редактирование заказа" Height="560" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtWindowTitle" FontSize="20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Артикул заказа:"/>
            <TextBlock x:Name="txtOrderNumber"/>

            <TextBlock Text="Статус заказа:"/>
            <ComboBox x:Name="cmbStatus" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Покупатель:"/>
            <ComboBox x:Name="cmbUsers" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Адрес пункта выдачи:"/>
            <ComboBox x:Name="cmbPickupPoint" DisplayMemberPath="FullAddress" SelectedValuePath="Id"/>

            <TextBlock Text="Дата заказа:"/>
            <DatePicker x:Name="dpOrderDate"/>

            <TextBlock Text="Дата доставки:"/>
            <DatePicker x:Name="dpDeliveryDate" DisplayDateStart="{Binding ElementName=dpOrderDate, Path=SelectedDate}"/>
        </StackPanel>

        <Border Grid.Row="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Товары в заказе: "/>

                <DataGrid x:Name="dgOrderItems" 
                          Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Height="100">

                    <DataGrid.Columns>
                        <DataGridComboBoxColumn Header="Товар" 
                                                SelectedValueBinding="{Binding ProductId}"
                                                SelectedValuePath="Id"
                                                DisplayMemberPath="Article">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style>
                                    <Setter Property="ComboBox.ItemsSource" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ProductsList}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style>
                                    <Setter Property="ComboBox.ItemsSource" Value="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ProductsList}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>

                        <DataGridTextColumn Header="Количество" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2" 
                        Content="Добавить товар"
                        Width="120" Height="30"
                        HorizontalAlignment="Left"
                        Click="btnAddItem_Click"/>
            </Grid>
        </Border>

        <TextBlock x:Name="txtError" Grid.Row="3" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Height="30" Click="BtnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить товар" Width="100" Height="30" Click="BtnDelete_Click" Visibility="Collapsed"/>
            <Button Content="Отмена" Width="100" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
